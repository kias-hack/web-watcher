[Unit]
Description=Web Watcher - site availability and checks monitor
ConditionFileIsExecutable=/usr/local/bin/web-watcher
After=network.target

[Service]
StartLimitInterval=5
StartLimitBurst=10
User=omir
Group=omir
ExecStart=/usr/local/bin/web-watcher "-config" "/etc/web-watcher/config.toml"
Restart=always
RestartSec=120

[Install]
WantedBy=multi-user.target
